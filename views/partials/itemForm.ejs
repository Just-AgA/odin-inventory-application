<form method="POST" action="<%= action %>">
  <input
    name="name"
    placeholder="Item name"
    value="<%= item?.name || '' %>"
    required
  />

  <textarea name="description"><%= item?.description || '' %></textarea>

  <input
    type="number"
    name="price"
    placeholder="Price"
    value="<%= item?.price || '' %>"
    required
  />

  <input
    type="number"
    name="quantity"
    placeholder="Quantity"
    value="<%= item?.quantity || '' %>"
    required
  />

  <input
    type="hidden"
    name="category_id"
    value="<%= item?.category_id || categoryId %>"
  />

  <button><%= buttonText %></button>
</form>
