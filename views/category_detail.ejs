<a href="/" class="back-btn">
  <button class="secondary">← Back</button>
</a><% if (typeof error !== 'undefined' && error === 'hasItems') { %>

  <div class="alert danger">
    Cannot delete category: it still has items! 
  </div>
<% } %>

<h1><%= category.name %></h1>

<div class="card">
  <h3>Add Item</h3>
  <%- include('partials/itemForm', {
    action: '/items/new',
    buttonText: 'Add Item',
    item: null,
    categoryId: category.id
  }) %>
</div>

