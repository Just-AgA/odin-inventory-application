<a href="/" class="back-btn">
  <button class="secondary">← Back</button>
</a><% if (typeof error !== 'undefined' && error === 'hasItems') { %>

  <div class="alert danger">
    Cannot delete category: it still has items! 
  </div>
<% } %>

<h1><%= category.name %></h1>

<div class="card">
  <h3>Add Item</h3>
  <%- include('partials/itemForm', {
    action: '/items/new',
    buttonText: 'Add Item',
    item: null,
    categoryId: category.id
  }) %>
</div>

<h2>Items</h2>

<% items.forEach(i => { %>
  <div class="card">

    <div class="row">
      <div>
        <a href="/items/<%= i.id %>"><strong><%= i.name %></strong></a>
        <div class="muted">Price: <%= i.price %>£ | Quantity: <%= i.quantity %></div>
      </div>

      <button class="secondary" onclick="toggleEdit(this)">Edit</button>
    </div>

    <div class="edit-form" style="display:none; margin-top:15px;">
      <%- include('partials/itemForm', {
        action: '/items/' + i.id + '/edit',
        buttonText: 'Update Item',
        item: i
      }) %>

      <form method="POST" action="/items/<%= i.id %>/delete">
        <button class="danger">Delete</button>
      </form>
    </div>

  </div>
<% }) %>

