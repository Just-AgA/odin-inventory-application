<h1>Categories</h1>

<div class="card">
  <h3>Add Category</h3>
  <%- include('partials/categoryForm', {
    action: '/categories/new',
    buttonText: 'Add Category',
    category: null
  }) %>
</div>

<% categories.forEach(c => { %>
  <div class="card">

    <div class="row">
      <div>
        <a href="/categories/<%= c.id %>"><strong><%= c.name %></strong></a>
        <% if (c.description) { %>
          <div class="muted"><%= c.description %></div>
        <% } %>
      </div>

      <div class="actions">
        <button class="secondary"
          onclick="this.closest('.card').querySelector('.edit-form').style.display='block'; this.style.display='none'">
          Edit
        </button>
      </div>
    </div>

    <div class="edit-form" style="display:none; margin-top:15px;">
      <%- include('partials/categoryForm', {
        action: '/categories/' + c.id + '/edit',
        buttonText: 'Update Category',
        category: c
      }) %>

      <form method="POST" action="/categories/<%= c.id %>/delete">
        <input name="admin_password" placeholder="Admin password" type="password" required />
        <button class="danger">Delete</button>
      </form>
    </div>

  </div>
<% }) %>