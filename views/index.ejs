<h1>Categories</h1>

<div class="card">
  <h3>Add Category</h3>
  <%- include('partials/categoryForm', {
    action: '/categories/new',
    buttonText: 'Add Category',
    category: null
  }) %>
</div>

<% categories.forEach(c => { %>
  <div class="card">

    <div class="row">
      <div>
        <a href="/categories/<%= c.id %>"><strong><%= c.name %></strong></a>
        <% if (c.description) { %>
          <div class="muted"><%= c.description %></div>
        <% } %>
      </div>

      

  </div>
<% }) %>